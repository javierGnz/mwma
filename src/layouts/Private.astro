---
import Layout from "./Layout.astro";
import Sidebar from "@/features/layout/Sidebar.astro";
import Navbar from "@/features/layout/Navbar.astro";
---

<Layout>
	<div class="grid min-h-dvh grid-cols-1 lg:grid-cols-[250px_1fr]">
		<Sidebar />
		<div class="flex flex-col lg:items-center">
			<div class="lg:container lg:p-4">
				<Navbar />
			</div>
			<main class="p-4 lg:container">
				<slot />
			</main>
		</div>
	</div>
</Layout>
